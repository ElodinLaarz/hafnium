#!/usr/bin/env bash
# Auto-format and lint staged GDScript files.
# gdformat and gdlint are part of gdtoolkit: pip install gdtoolkit
#
# One-time setup (from repo root):
#   git config core.hooksPath .githooks
#
# Note: gdlint reports issues but does not auto-fix them. We run gdformat
# first to apply safe formatting fixes, then gdlint as a blocking check.

set -euo pipefail

REPO_ROOT=$(git rev-parse --show-toplevel)
PROJECT_DIR="$REPO_ROOT/Hafnium"
GUT_RUNNER="$PROJECT_DIR/addons/gut/gut_cmdln.gd"
TYPE_HINT_CHECKER="$REPO_ROOT/.githooks/check_gdscript_type_hints.py"

if command -v python3 &> /dev/null; then
    PYTHON_BIN="python3"
elif command -v python &> /dev/null; then
    PYTHON_BIN="python"
else
    PYTHON_BIN=""
fi

mapfile -d '' STAGED_FILES < <(git diff --cached --name-only -z --diff-filter=ACM -- '*.gd')

if [ "${#STAGED_FILES[@]}" -eq 0 ]; then
    exit 0
fi

if ! command -v gdformat &> /dev/null; then
    echo "[pre-commit] gdformat not found — skipping GDScript formatting."
    echo "             Install with: pip install gdtoolkit"
else
    echo "[pre-commit] Formatting GDScript files..."
    gdformat "${STAGED_FILES[@]}"
    git add -- "${STAGED_FILES[@]}"
fi

if ! command -v gdlint &> /dev/null; then
    echo "[pre-commit] gdlint not found — skipping GDScript linting."
    echo "             Install with: pip install gdtoolkit"
else
    echo "[pre-commit] Linting GDScript files..."
    if ! gdlint "${STAGED_FILES[@]}"; then
        echo "[pre-commit] gdlint found errors. gdformat was applied, but gdlint issues must be fixed manually."
        exit 1
    fi
fi

if [ -z "$PYTHON_BIN" ]; then
    echo "[pre-commit] Python not found — skipping type-hint linting."
elif [ ! -f "$TYPE_HINT_CHECKER" ]; then
    echo "[pre-commit] Type-hint checker not found — skipping type-hint linting."
else
    echo "[pre-commit] Checking GDScript type hints..."
    if ! "$PYTHON_BIN" "$TYPE_HINT_CHECKER" "${STAGED_FILES[@]}"; then
        echo "[pre-commit] Missing GDScript type hints detected."
        exit 1
    fi
fi

if [ ! -f "$GUT_RUNNER" ]; then
    echo "[pre-commit] GUT not found — skipping unit tests."
    echo "             Install locally before relying on presubmit tests."
else
    echo "[pre-commit] Running GUT tests..."
    if ! bash "$PROJECT_DIR/run_tests.sh"; then
        echo "[pre-commit] GUT tests failed."
        exit 1
    fi
fi

echo "[pre-commit] Done."
